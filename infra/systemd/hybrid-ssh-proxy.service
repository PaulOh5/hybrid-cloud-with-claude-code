[Unit]
Description=Hybrid Cloud — ssh-proxy (public SSH entry point)
After=network-online.target hybrid-main-api.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/hybrid-cloud
EnvironmentFile=%h/hybrid-cloud/.env.production
ExecStart=%h/hybrid-cloud/bin/ssh-proxy
Restart=on-failure
RestartSec=3
KillSignal=SIGTERM
TimeoutStopSec=15
StandardOutput=journal
StandardError=journal
SyslogIdentifier=hybrid-ssh-proxy
# Privileged port binding (e.g. :22) requires CAP_NET_BIND_SERVICE. Use a
# user-level setcap on the binary or run on a high port and front it with
# nftables. Default ssh-proxy port lives in .env.production.

[Install]
WantedBy=default.target
