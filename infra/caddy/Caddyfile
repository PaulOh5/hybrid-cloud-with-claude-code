{
	email ops@qlaud.net

	# DNS-01 challenge via Route53. h20a's firewall blocks foreign IPs on
	# :80/:443, so HTTP-01 / TLS-ALPN-01 cannot complete — Let's Encrypt's
	# validators come from rotating non-KR vantage points and are not
	# allow-listable. DNS-01 only needs outbound HTTPS to the Route53 API.
	acme_dns route53 {
		max_retries 5
	}
}

# Wildcard + apex: Phase 2 mux.qlaud.net + Phase 3 future subdomains all
# served from a single cert pair. Wildcard requires DNS-01 (configured in
# the global block above). The apex needs its own cert because Let's
# Encrypt wildcards do not cover the parent domain.
*.qlaud.net, qlaud.net {
	encode zstd gzip

	# Frontend (Next.js standalone) handles all paths for the public app
	# hostnames and rewrites /api/v1/* to main-api internally — see
	# web/frontend/next.config.ts.
	@app host qlaud.net www.qlaud.net
	handle @app {
		reverse_proxy 127.0.0.1:3000
	}

	# Other subdomains (mux.qlaud.net etc.) get the wildcard cert but no
	# routing yet. Phase 2.1 Task 1.1 wires mux.qlaud.net into ssh-proxy
	# via an L4 stream forward; until then these return 404 so misrouted
	# clients fail loudly.
	handle {
		respond "service not configured for this hostname" 404
	}
}
