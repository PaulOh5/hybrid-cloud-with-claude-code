# --- main-api ---
MAIN_API_HTTP_ADDR=:8080
MAIN_API_GRPC_ADDR=:8081
MAIN_API_ADMIN_TOKEN=dev-admin-token-change-me
MAIN_API_AGENT_TOKEN=dev-agent-token-change-me

# --- postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=hybrid
POSTGRES_PASSWORD=hybrid
POSTGRES_DB=hybrid
DATABASE_URL=postgres://hybrid:hybrid@localhost:5432/hybrid?sslmode=disable

# --- compute-agent ---
AGENT_NODE_NAME=dev-node-01
AGENT_API_ENDPOINT=localhost:8081
AGENT_API_TOKEN=dev-agent-token-change-me

# --- ssh-proxy ---
SSH_PROXY_LISTEN=:2222
SSH_PROXY_API_ENDPOINT=http://localhost:8080

# --- frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080
